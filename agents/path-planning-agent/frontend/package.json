{
  "name": "drone-planner",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "无人机配送路径规划智能体",
  "author": "洗秋人午言",
  "repository": {
    "type": "git",
    "url": "https://github.com/Marvin699/UAV-agen.git"
  },
  "main": "electron/main.js",
  "scripts": {
  "dev": "vite",
  "build": "vite build",
  "preview": "vite preview",
  "electron:dev": "electron .",
  "electron:build": "npm run build-vite && electron-builder --win",
  "postinstall": "npm run build-vite || true",
  "build-vite": "vite build"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "leaflet": "^1.9.4",
    "marked": "^18.0.4",
    "pinia": "^3.0.4",
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.12",
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "productName": "无人机配送路径规划智能体",
    "appId": "com.xiqiurenwuyan.drone-planner",
    "copyright": "Copyright (C) 2026 洗秋人午言",
    "directories": {
      "output": "electron-dist",
      "buildResources": "public"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend/dist",
        "to": "backend/dist"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/favicon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "public/favicon.ico",
      "uninstallerIcon": "public/favicon.ico",
      "installerHeaderIcon": "public/favicon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
